#!/bin/bash

aws configure

aws s3api create-bucket \
  --bucket balajipracticee.k8s.local \
  --region us-east-1

aws s3api put-bucket-versioning \
  --bucket balajipracticee.k8s.local \
  --region us-east-1 \
  --versioning-configuration Status=Enabled

curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"

wget https://github.com/kubernetes/kops/releases/download/v1.33.0/kops-linux-amd64

chmod +x kubectl kops-linux-amd64

sudo mv kubectl /usr/local/bin/kubectl
sudo mv kops-linux-amd64 /usr/local/bin/kops

echo 'export PATH=$PATH:/usr/local/bin' >> ~/.bashrc
echo 'export KOPS_STATE_STORE=s3://balajipracticee.k8s.local' >> ~/.bashrc
source ~/.bashrc

export KOPS_STATE_STORE=s3://balajipracticee.k8s.local

kops create cluster \
  --name balajipracticee.k8s.local \
  --cloud aws \
  --zones us-east-1a \
  --control-plane-count 1 \
  --control-plane-size c7i-flex.large \
  --node-count 2 \
  --node-size c7i-flex.large \
  --dns private

kops update cluster --name balajipracticee.k8s.local --yes --admin
